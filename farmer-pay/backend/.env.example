# Copy this file to .env and fill in real values.
# NEVER commit .env to git — it is in .gitignore.

# MongoDB Atlas — get from cloud.mongodb.com → Connect → Drivers
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/farmerpay

# Algorand free public TestNet endpoints — no key needed
ALGORAND_NODE=https://testnet-api.algonode.cloud
ALGORAND_INDEXER=https://testnet-idx.algonode.cloud

# Deployed contract App ID — fill after: algokit project deploy testnet
CONTRACT_APP_ID=0

# Pinata IPFS — from https://app.pinata.cloud/keys
PINATA_API_KEY=
PINATA_SECRET=

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace_with_a_very_long_random_string
JWT_EXPIRE_HOURS=24

# Server
PORT=4000

# Frontend URL for CORS — set to Vercel URL in production
FRONTEND_URL=http://localhost:5173
